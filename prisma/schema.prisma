generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// HİZMET KATEGORİLERİ
// ============================================
model ServiceCategory {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  order              Int       @default(0)
  // Hub Sayfası İçerik Alanları
  heroTitle          String?
  heroContent        String?   @db.Text
  // SEO Alanları
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  services           Service[]
  // English Fields
  slug_en            String?   @unique
  name_en            String?
  metaTitle_en       String?
  metaDescription_en String?
  metaKeywords_en    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// HİZMETLER
// ============================================
model Service {
  id                 String          @id @default(cuid())
  title              String
  slug               String
  description        String?
  content            String?         @db.Text
  image              String? // Cover görsel
  gallery            String?         @db.Text // JSON array - galeri görselleri
  video              String? // Video URL (Cloudinary)
  videoThumbnailTime Float? // Kapak fotoğrafı için saniye
  size               String          @default("medium")
  bgColor            String?
  textColor          String          @default("light")
  order              Int             @default(0)
  featured           Boolean         @default(false) // Anasayfada göster
  featuredOrder      Int             @default(0) // Anasayfa sırası
  categoryId         String
  category           ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  // SEO Alanları
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  ogImage            String?
  // English Fields
  slug_en            String?
  title_en           String?
  description_en     String?
  content_en         String?         @db.Text
  metaTitle_en       String?
  metaDescription_en String?
  metaKeywords_en    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, slug])
  @@index([categoryId])
}

// ============================================
// PROJELER
// ============================================
model Project {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  description  String?
  content      String?   @db.Text // Detaylı proje açıklaması
  image        String? // Ana kapak görseli
  gallery      String?   @db.Text // JSON array - galeri görselleri
  category     String? // Proje kategorisi (Web, Mobil, AI, vb.)
  client       String? // Müşteri adı
  projectDate  DateTime? // Proje tamamlanma tarihi
  technologies String?   @db.Text // JSON array - kullanılan teknolojiler
  projectUrl   String? // Canlı proje linki
  githubUrl    String? // GitHub linki (varsa)
  featured     Boolean   @default(false) // Öne çıkan proje mi?
  published    Boolean   @default(true) // Yayında mı?
  order        Int       @default(0) // Sıralama

  // SEO Alanları
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?

  // English Fields
  slug_en            String?   @unique
  title_en           String?
  description_en     String?
  content_en         String? @db.Text
  metaTitle_en       String?
  metaDescription_en String?
  metaKeywords_en    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, featured, order])
}

// ============================================
// BLOG YAZILARI
// ============================================
model BlogPost {
  id                 String    @id @default(cuid())
  title              String
  slug               String    @unique
  excerpt            String?
  content            String?   @db.Text
  image              String?
  category           String?
  author             String?
  published          Boolean   @default(false)
  publishedAt        DateTime?
  // SEO Alanları
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  ogImage            String?
  // English Fields
  slug_en            String?   @unique
  title_en           String?
  excerpt_en         String?
  content_en         String?   @db.Text
  metaTitle_en       String?
  metaDescription_en String?
  metaKeywords_en    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// SİTE AYARLARI (Global SEO)
// ============================================
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// İLETİŞİM FORMU
// ============================================
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String?
  createdAt DateTime @default(now())
}

// ============================================
// KULLANICILAR (Admin Panel)
// ============================================
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// ANALİTİKS
// ============================================

// Sayfa görüntülemeleri
model PageView {
  id        String   @id @default(cuid())
  path      String // Örn: /hizmetler/yapay-zeka/ai-photo
  sessionId String // Browser fingerprint veya session ID
  referer   String? // Nereden geldi
  userAgent String? // Tarayıcı bilgisi
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

// Event tracking (menü tıklamaları, arama, vb.)
model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String // 'menu_click', 'search', 'service_view', 'category_view'
  eventData String?  @db.Text // JSON - ek veriler
  sessionId String
  path      String // Hangi sayfada oldu
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

// ============================================
// MEDYA KÜTÜPHANESİ
// ============================================
model Media {
  id        String   @id @default(cuid())
  url       String
  publicId  String   @unique // Cloudinary public_id
  fileName  String?
  fileType  String? // image, video, vb.
  fileSize  Int?
  folder    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
