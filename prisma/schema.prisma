generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ServiceCategory {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  order              Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  metaDescription    String?
  metaKeywords       String?
  metaTitle          String?
  metaDescription_en String?
  metaTitle_en       String?
  name_en            String?
  slug_en            String?   @unique
  heroContent        String?
  heroTitle          String?
  metaKeywords_en    String?
  services           Service[]
}

model Service {
  id                 String          @id @default(cuid())
  title              String
  slug               String
  description        String?
  content            String?
  image              String?
  size               String          @default("medium")
  bgColor            String?
  textColor          String          @default("light")
  order              Int             @default(0)
  categoryId         String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  metaDescription    String?
  metaKeywords       String?
  metaTitle          String?
  ogImage            String?
  gallery            String?
  video              String?
  videoThumbnailTime Float?
  content_en         String?
  description_en     String?
  metaDescription_en String?
  metaKeywords_en    String?
  metaTitle_en       String?
  title_en           String?
  featured           Boolean         @default(false)
  featuredOrder      Int             @default(0)
  slug_en            String?
  category           ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
  @@index([categoryId])
}

model Project {
  id                 String    @id @default(cuid())
  title              String
  slug               String    @unique
  description        String?
  content            String?
  image              String?
  gallery            String?
  category           String?
  client             String?
  projectDate        DateTime?
  technologies       String?
  projectUrl         String?
  githubUrl          String?
  featured           Boolean   @default(false)
  published          Boolean   @default(true)
  order              Int       @default(0)
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  ogImage            String?
  title_en           String?
  description_en     String?
  content_en         String?
  metaTitle_en       String?
  metaDescription_en String?
  metaKeywords_en    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  slug_en            String?   @unique
  video              String?

  @@index([published, featured, order])
}

model BlogPost {
  id                 String    @id @default(cuid())
  title              String
  slug               String    @unique
  excerpt            String?
  content            String?
  image              String?
  category           String?
  published          Boolean   @default(false)
  publishedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  author             String?
  metaDescription    String?
  metaKeywords       String?
  metaTitle          String?
  ogImage            String?
  content_en         String?
  excerpt_en         String?
  metaDescription_en String?
  metaKeywords_en    String?
  metaTitle_en       String?
  title_en           String?
  slug_en            String?   @unique
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String?
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  sessionId String
  referer   String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String
  eventData String?
  sessionId String
  path      String
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

model SectorPage {
  id                 String   @id @default(cuid())
  title              String
  slug               String   @unique
  h1                 String?
  excerpt            String?
  content            String?
  images             String?
  published          Boolean  @default(false)
  order              Int      @default(0)
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  ogImage            String?
  customSchema       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  content_en         String?
  excerpt_en         String?
  h1_en              String?
  metaDescription_en String?
  metaKeywords_en    String?
  metaTitle_en       String?
  slug_en            String?  @unique
  serviceIds         String?
}

model Media {
  id        String   @id @default(cuid())
  url       String
  publicId  String   @unique
  fileName  String?
  fileType  String?
  fileSize  Int?
  folder    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
